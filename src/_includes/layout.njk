<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }} - {{ site.tagline }}{% endif %}</title>
<meta name="description" content="{{ description or site.description }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' rx='5' fill='%232563eb'/%3E%3Cpath d='M6 12h3m6 0h3M12 6v3m0 6v3' stroke='%23fff' stroke-width='2' stroke-linecap='round'/%3E%3Ccircle cx='12' cy='12' r='2.5' fill='%23fff'/%3E%3C/svg%3E">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.name }}{% endif %}">
<meta property="og:description" content="{{ description or site.description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta name="twitter:card" content="summary">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true"></span>
      {{ site.name }}
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/">Home</a>
      <a href="/about/">About</a>
    </nav>
  </div>
</header>

<main>
  <div class="wrap">
    <!-- AD SLOT: top-of-page unit goes here once AdSense is approved -->
    {{ content | safe }}
  </div>
</main>

<footer class="site-footer">
  <div class="wrap">
    <p>&copy; {{ site.year }} {{ site.name }}. All calculations are provided as-is for reference; verify critical designs independently.</p>
    <p><a href="/about/">About</a> &middot; <a href="/privacy-policy/">Privacy Policy</a></p>
  </div>
</footer>
</body>
</html>
